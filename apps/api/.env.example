DATABASE_URL=
CORS_ORIGINS=
LOG_REQUESTS=
# Mount the Swagger UI + OpenAPI spec at /api. Off unless set to "true" (secure
# default). Enable on local + test; leave UNSET in prod.
SWAGGER_ENABLED=true

JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# A1 — Microsoft Entra SSO (OIDC). Ships gated OFF: leave OIDC_ENABLED unset and
# the /auth/oidc/* routes 404. Flip to true only AFTER the app registration exists
# and the vars below are set (deploy code before flipping the flag).
OIDC_ENABLED=
OIDC_TENANT_ID=            # Entra Directory (tenant) ID
OIDC_CLIENT_ID=           # the SSO app registration's Application (client) ID
OIDC_CLIENT_SECRET=       # a client secret on that app registration
OIDC_REDIRECT_URI=        # e.g. https://<api-host>/v1/auth/oidc/callback (+ localhost for dev)
OIDC_WEB_CALLBACK_URL=    # e.g. https://<web-host>/auth/callback
OIDC_ORG_ID=              # Organization UUID to assign SSO users (optional if only one org)
# App roles to define on the registration -> platform role:
#   OrgOwner, OrgAdmin, ServiceManager, ServiceDeskAnalyst, Engineer

# storage abstraction
STORAGE_PROVIDER=s3

S3_ENDPOINT=http://minio:9000
S3_BUCKET=dcms-attachments
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-west-2
S3_FORCE_PATH_STYLE=true

# Azure placeholders (Phase 2)
# In Azure we use managed identity (DefaultAzureCredential) — no connection string needed;
# set AZURE_STORAGE_ACCOUNT + AZURE_STORAGE_CONTAINER only.
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_CONNECTION_STRING=
