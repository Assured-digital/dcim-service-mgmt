// Soft-link join table — connects any two work-item records (Incident, Service
// Request, Change, Task, Risk, Issue) within a single client. Polymorphic: the two
// endpoints are stored as opaque (type, id) pairs rather than FK relations, so a
// link can span types without 12 back-relations across 6 models. Tenant integrity
// is enforced in application code (the established where:{id,clientId} pattern) —
// every endpoint is validated against clientId before a row is written.
//
// A link is bidirectional/symmetric: (A,B) == (B,A). The service writes endpoints
// in a canonical order (the smaller "type:id" string as endpoint A) so the unique
// constraint actually collapses duplicates. Lookups must therefore query BOTH
// endpoint positions (hence the two indexes).
model RecordLink {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  aType       String
  aId         String
  bType       String
  bId         String
  createdById String?
  createdAt   DateTime @default(now())

  @@unique([clientId, aType, aId, bType, bId])
  @@index([clientId, aType, aId])
  @@index([clientId, bType, bId])
}

// File attachments on the six work-item record types. Like RecordLink, the
// (recordType, recordId) pair is a polymorphic, clientId-scoped pointer — tenant
// integrity is enforced in app code via where: { id, clientId }. The bytes live in
// object storage (storageKey); the DB holds metadata only. contentType is the
// SERVER-validated (magic-byte) MIME, never the raw upload header.
model Attachment {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  recordType   String // incident | service_request | change | task | risk | issue | maintenance | check
  recordId     String
  filename     String // original client filename (display only — never trusted for type)
  contentType  String // server-validated canonical MIME (magic-byte verified)
  size         Int // bytes
  storageKey   String // object key in the bucket
  caption      String? // optional short label captured with the evidence (frictionless); editable until the owning check locks
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([clientId, recordType, recordId])
}

// Timestamped work notes on the DCIM estate entities (asset / cabinet / site) —
// the Hyperview "Work Notes" pattern, field-ops friendly. Same polymorphic
// clientId-scoped pointer shape as Attachment; tenant integrity enforced in app
// code (entity validated in-scope on write, clientId on every read).
model WorkNote {
  id         String   @id @default(uuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])
  entityType String // asset | cabinet | site
  entityId   String
  authorId   String?
  author     User?    @relation("UserWorkNotes", fields: [authorId], references: [id])
  body       String
  createdAt  DateTime @default(now())

  @@index([clientId, entityType, entityId])
}

model Comment {
  id                String           @id @default(uuid())
  authorId          String
  author            User             @relation("UserComments", fields: [authorId], references: [id])
  body              String
  // Rich-text representation (additive, nullable). Existing plain-text comments
  // keep `body` and leave this NULL — `body` stays the plain-text fallback. New
  // rich comments populate bodyJson (Phase 1 rich comments, later stage). No backfill.
  bodyJson          Json?
  entityType        String
  entityId          String
  type              String           @default("WORK_NOTE")
  visibleToCustomer Boolean          @default(false)
  fromCustomer      Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  serviceRequestId  String?
  serviceRequest    ServiceRequest?  @relation("ServiceRequestComments", fields: [serviceRequestId], references: [id])
  mentions          CommentMention[]
  // Two-level (Slack-style) threading, additive. NULL = top-level comment (a
  // "post"); set = a reply to that top-level comment. Two-level ONLY: a reply's
  // parentCommentId must point at a top-level comment (one whose own
  // parentCommentId is NULL) — "no reply to a reply" is enforced in the create
  // logic (later stage), not the schema. Self-relation below. On-delete CASCADE:
  // deleting a top-level comment drops its whole thread of replies (mirrors how
  // CommentMention cascades off Comment). Existing comments get NULL = top-level.
  parentCommentId   String?
  parent            Comment?         @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies           Comment[]        @relation("CommentReplies")

  @@index([parentCommentId])
}

// Polymorphic mention join table: a comment mentions one or more targets, each an
// opaque (targetType, targetId) pair — mirrors RecordLink's philosophy (no typed
// FK to the target, tenant integrity enforced in app code). Designed generic from
// day one (user | asset | record); Phase 1 only writes `user`. Mentions store the
// pointer ONLY — displayName is resolved at read time (the #99 convention), never
// denormalised here. FK to Comment cascades: deleting a comment drops its mentions.
model CommentMention {
  id         String   @id @default(uuid())
  commentId  String
  comment    Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  targetType String // user | asset | record (Phase 1: user only)
  targetId   String
  createdAt  DateTime @default(now())

  @@index([commentId])
  @@index([targetType, targetId])
}

// In-app notification. Generic/polymorphic from day one: Phase 2 writes MENTION
// only, but the shape (recipient + actor + opaque source pointer + client scope)
// carries every future kind without reshaping.
//
// Source pointer = the NAVIGATION TARGET, not the literal trigger: (sourceType,
// sourceId) is the record the user clicks through to — a Comment's parent record
// (entityType/entityId in the Comment vocabulary: Incident, ServiceRequest,
// ChangeRequest, Task, Risk, Issue, Asset). For a MENTION that's the record whose
// activity feed holds the comment; for a future ASSIGNED it'd be the assigned
// record. `commentId` is the mention-specific extra — the comment to scroll/
// highlight on arrival. Like RecordLink/CommentMention it's an opaque pointer (no
// FK to Comment), so the generic model stays decoupled from any one source kind;
// if the comment is gone the click still lands on the record.
//
// Unlike comments (which inherit tenant via their parent), a notification carries
// its OWN clientId — set on emit from the triggering request context — so it is
// directly scopable with the standard where:{ ..., clientId } pattern.
model Notification {
  id          String           @id @default(uuid())
  recipientId String
  recipient   User             @relation("ReceivedNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  type        NotificationType
  actorId     String?
  actor       User?            @relation("TriggeredNotifications", fields: [actorId], references: [id], onDelete: SetNull)
  clientId    String
  client      Client           @relation(fields: [clientId], references: [id])
  sourceType  String
  sourceId    String
  commentId   String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  // "my unread notifications, newest first" — the bell's primary query.
  @@index([recipientId, readAt, createdAt])
  @@index([clientId])
}

model UserClientAssignment {
  id        String   @id @default(cuid())
  userId    String
  clientId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([userId])
  @@index([clientId])
}
