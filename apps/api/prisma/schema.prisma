generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ORG_OWNER
  ORG_ADMIN
  ADMIN
  SERVICE_MANAGER
  SERVICE_DESK_ANALYST
  ENGINEER
  CLIENT_VIEWER
  PUBLIC_USER
}

enum OwnerType {
  INTERNAL
  CLIENT
}

enum ServiceRequestStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  WAITING_CUSTOMER
  COMPLETED
  CLOSED
  CANCELLED
}

enum CheckStatus {
  DRAFT
  SCHEDULED
  ASSIGNED
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
  CLOSED
  CANCELLED
}

enum CheckItemResponseType {
  PASS_FAIL
  PASS_FAIL_NA
}

enum IncidentStatus {
  NEW
  INVESTIGATING
  MITIGATED
  RESOLVED
  CLOSED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum MaintenanceWorkType {
  INSPECTION
  PSU_REPLACEMENT
  FIRMWARE_UPGRADE
  PAT_INSPECTION
  COOLING_CHECK
  CABLE_AUDIT
  REPAIR
  UPGRADE
  OTHER
}

enum RequestIntakeStatus {
  NEW
  UNDER_REVIEW
  CONVERTED
  REJECTED
}

enum AssetLifecycleState {
  PLANNED
  PROCUREMENT
  STAGING
  ACTIVE
  RETIRED
}

enum ConnectionStatus {
  PLANNED
  ACTIVE
  DEGRADED
  RETIRED
}

// Airflow direction on a DeviceType (DCIM spec §1) — the NetBox vocabulary minus
// the left/right variants nobody in the estate uses; additive to extend.
enum DeviceAirflow {
  FRONT_TO_REAR
  REAR_TO_FRONT
  SIDE_TO_REAR
  PASSIVE
  MIXED
}

// Notification kinds. Phase 2 emits MENTION only; the enum is the additive seam for
// future kinds (ASSIGNED, STATUS_CHANGED, …) — adding a value is a one-line migration.
enum NotificationType {
  MENTION
  REPLY
  ASSIGNED
  STATUS_CHANGED
}

model Client {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  name           String
  status         String        @default("ACTIVE")
  // CRM lifecycle (CRM_DESIGN.md §2): PROSPECT | ONBOARDING | ACTIVE | FORMER.
  // Never auto-downgraded; transitions are deliberate staff edits (or the WON prompt).
  lifecycleStage String        @default("ACTIVE")
  // CRM_DESIGN.md §8 — folder within the org SharePoint site (dormant until phase 7a)
  sharePointFolderPath String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  serviceRequests   ServiceRequest[]
  assets            Asset[]
  notifications     Notification[]
  checks            Check[]                @relation("ClientChecks")
  checkTemplates    CheckTemplate[]        @relation("ClientCheckTemplates")
  incidents         Incident[]
  tasks             Task[]
  sites             Site[]
  workPackages      WorkPackage[]
  changeRequests    ChangeRequest[]
  risks             Risk[]
  issues            Issue[]
  publicSubmissions PublicSubmission[]
  documents         DocumentReference[]
  requestIntakes    RequestIntake[]
  connections       Connection[]
  userAssignments   UserClientAssignment[]
  recordLinks       RecordLink[]
  attachments       Attachment[]
  workNotes         WorkNote[]
  sensorReadings    SensorReading[]
  assetCustomFields AssetCustomField[]
  slaPolicies       SlaPolicy[]
  cabinetReservations CabinetReservation[]
  regions           Region[]
  importMappings    ImportMapping[]
  contacts          Contact[]
}

// CRM (CRM_DESIGN.md §4) — a person AT the client (no login, not a User).
model Contact {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  firstName String
  lastName  String
  jobTitle  String?
  email     String?  // match key for email sync (phase 7b)
  phone     String?
  mobile    String?
  siteId    String?  // optional: primarily based at this site
  site      Site?    @relation(fields: [siteId], references: [id])
  category  String   @default("GENERAL") // DECISION_MAKER | TECHNICAL | BILLING | OPERATIONS | ACCESS | GENERAL
  isPrimary Boolean  @default(false)     // the main account contact for this client
  userId    String?  // optional link to a portal User (display-only)
  notes     String?
  status    String   @default("ACTIVE")  // ACTIVE | INACTIVE (soft delete)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, status])
  @@index([email]) // cross-client lookup for email-sync matching (phase 7b)
}

model SlaPolicy {
  id              String   @id @default(uuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  priority        String
  resolutionHours Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clientId, priority])
  @@index([clientId])
}

model Site {
  id         String    @id @default(uuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id])
  name       String
  address    String?
  city       String?
  postcode   String?
  country    String    @default("UK")
  latitude   Float?
  longitude  Float?
  geocodedAt DateTime?
  notes      String?
  // Contracted capacity (DCIM spec §5) — commercial figures set by staff; the
  // denominators for the client-facing infrastructure report. Sites are
  // single-client-owned, so per-site is the contract unit (no allocation entity).
  contractedKw Float?
  contractedU  Int?
  // ── Latent (DCIM_SCHEMA_SPEC §5 / §7) ──
  regionId   String?   // groups sites when the multi-site estate view is built
  region     Region?   @relation(fields: [regionId], references: [id])
  status     String?   // future "site under maintenance" states
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  rooms            Room[]
  cabinets         Cabinet[]
  assets           Asset[]
  checks           Check[]           @relation("SiteChecks")
  checkTemplates   CheckTemplate[]   @relation("SiteCheckTemplates")
  workPackageSites WorkPackageSite[]
  contacts         Contact[]
}

// Geography above Site (DCIM_SCHEMA_SPEC §5, LATENT — no phase-one UI). Exists so
// a future region → sites roll-up needs no migration. Client-scoped.
model Region {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  name      String   // "UK South", "EMEA"
  createdAt DateTime @default(now())
  sites     Site[]

  @@index([clientId])
}

model Room {
  id        String   @id @default(uuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  type      String   @default("DATA_HALL")
  floor     String?
  notes     String?
  // ── Floor-plan canvas (DCIM_SCHEMA_SPEC §2.2 / §2.3) ──
  widthMm          Int?    // room dimensions — canvas scale for the architectural view
  depthMm          Int?
  gridCols         Int?    // optional snap-to-grid hints
  gridRows         Int?
  shellType        String? // "IMAGE" | "DRAWN" | null (no shell yet)
  backgroundImageKey String? // object-storage key for an uploaded plan image (backdrop)
  backgroundImageType String?
  backgroundOpacity Float?  @default(0.4)
  shellShape       Json?   // DRAWN: { type: "rect"|"L", points: [...] } — simple geometry, not CAD
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cabinets     Cabinet[]
  aisleZones   AisleZone[]
  floorObjects FloorObject[]
}

// Hot/cold aisle designation on the room canvas (DCIM_SCHEMA_SPEC §2.4). Scoped
// indirectly via room.site.clientId — spoof-test per §8.
model AisleZone {
  id        String   @id @default(uuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  type      String   // "HOT" | "COLD"
  geometry  Json     // area on the canvas: { x, y, w, h } (grid units) or points
  label     String?
  createdAt DateTime @default(now())

  @@index([roomId])
}

// Floor-level infrastructure placed on the plan — CRAC/UPS/PDU/column/door
// (DCIM_SCHEMA_SPEC §2.5). optional assetId links it to a tracked Asset (a CRAC
// can be both a floor object and a maintained asset). Scoped via room.site.clientId.
model FloorObject {
  id          String   @id @default(uuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  objectType  String   // "CRAC" | "UPS" | "PDU" | "COLUMN" | "DOOR"
  posX        Float
  posY        Float
  width       Float?   // canvas footprint (grid units); null = default per type
  depth       Float?
  orientation Int      @default(0)
  label       String?
  assetId     String?  // optional link to a tracked Asset
  asset       Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([roomId])
}

// Stored CSV column mapping for repeatable bulk import (DCIM_SCHEMA_SPEC §2.7).
// Client-scoped (direct). The import operation itself is idempotent app logic.
model ImportMapping {
  id         String   @id @default(uuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])
  name       String   // "Cardiff rack sheet"
  targetType String   // "CABINET" | "ASSET"
  columnMap  Json     // { "Rack Name": "cabinet.name", "Row": "cabinet.row", ... }
  createdAt  DateTime @default(now())

  @@index([clientId])
}

model CheckTemplate {
  id               String   @id @default(uuid())
  reference        String   @unique
  name             String
  checkType        String
  description      String?
  clientId         String?
  client           Client?  @relation("ClientCheckTemplates", fields: [clientId], references: [id])
  siteId           String?
  site             Site?    @relation("SiteCheckTemplates", fields: [siteId], references: [id])
  isActive         Boolean  @default(true)
  estimatedMinutes Int?
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items  CheckTemplateItem[]
  checks Check[]
}

model CheckTemplateItem {
  id           String                @id @default(uuid())
  templateId   String
  template     CheckTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sortOrder    Int
  section      String?
  label        String
  guidance     String?
  responseType CheckItemResponseType @default(PASS_FAIL)
  isRequired   Boolean               @default(true)
  isCritical   Boolean               @default(false)
  createdAt    DateTime              @default(now())
}

model Check {
  id                 String        @id @default(uuid())
  reference          String        @unique
  clientId           String
  client             Client        @relation("ClientChecks", fields: [clientId], references: [id])
  siteId             String
  site               Site          @relation("SiteChecks", fields: [siteId], references: [id])
  templateId         String
  template           CheckTemplate @relation(fields: [templateId], references: [id])
  checkType          String
  title              String
  status             CheckStatus   @default(DRAFT)
  priority           String        @default("medium")
  assigneeId         String?
  assignee           User?         @relation("AssignedCheck", fields: [assigneeId], references: [id])
  reviewerId         String?
  reviewer           User?         @relation("CheckReviewer", fields: [reviewerId], references: [id])
  scheduledAt        DateTime?
  startedAt          DateTime?
  submittedAt        DateTime?
  completedAt        DateTime?
  closedAt           DateTime?
  cancellationReason String?
  scopeNotes         String?
  engineerSummary    String?
  reviewerNotes      String?
  passRate           Float?
  createdById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  items CheckItem[]
}

model CheckItem {
  id             String                @id @default(uuid())
  checkId        String
  check          Check                 @relation(fields: [checkId], references: [id], onDelete: Cascade)
  templateItemId String?
  sortOrder      Int
  section        String?
  label          String
  guidance       String?
  responseType   CheckItemResponseType @default(PASS_FAIL)
  isRequired     Boolean               @default(true)
  isCritical     Boolean               @default(false)
  isAdHoc        Boolean               @default(false)
  response       String?
  notes          String?
  respondedAt    DateTime?
  respondedById  String?
  // Reviewer flag-for-rework (set on the PENDING_REVIEW surface; the engineer sees it on
  // return). Nullable/no-default so the migration is a pure ADD COLUMN — treat null as
  // not-flagged. Cleared on the next submit-for-review (fresh review round).
  reworkFlagged  Boolean?
  reworkNote     String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  followOns CheckItemFollowOn[]
}

model CheckItemFollowOn {
  id          String    @id @default(uuid())
  checkItemId String
  checkItem   CheckItem @relation(fields: [checkItemId], references: [id], onDelete: Cascade)
  entityType  String
  entityId    String
  note        String?
  createdById String?
  createdAt   DateTime  @default(now())
}

model Cabinet {
  id        String   @id @default(uuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id])
  roomId    String?
  room      Room?    @relation(fields: [roomId], references: [id])
  name      String
  type      String   @default("RACK")
  totalU    Int?
  // usedU is LEGACY — computed on read in CabinetsService since the DCIM
  // foundations migration (excludes excludeFromUtilization types). Not written.
  usedU     Int?
  powerKw   Float? // feed capacity (kW) — the power denominator (DCIM spec §4.1)
  // Bottom U number (default 1). Dormant until an estate needs non-1 numbering;
  // all U maths must honour it (DCIM spec §1).
  startingUnit Int    @default(1)
  maxWeightKg  Float? // weight capacity denominator; null = weight bar renders "—"
  // ── Spatial placement on the room floor plan (DCIM_SCHEMA_SPEC §2.1) ──
  row           String? // human label / grouping, e.g. "R3"
  positionInRow Int?    // slot within the row, 1-based → "R3-07"
  orientation   Int     @default(0) // rotation degrees: 0 | 90 | 180 | 270
  posX          Float?  // x on the room canvas (grid units); null = unplaced tray
  posY          Float?  // y on the room canvas
  // Physical footprint (mm) for the true-scale floor plan (Phase A). null → the
  // canvas assumes a standard 600 × 1070 mm cabinet.
  widthMm       Int?
  depthMm       Int?
  // Cabinet lifecycle for the floor-plan Status lens. String (not enum) to match
  // Asset.status; values resolve through entityStatusIntent (§8): ACTIVE | PLANNED
  // | DECOMMISSIONING | RETIRED.
  status        String  @default("ACTIVE")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets       Asset[]
  reservations CabinetReservation[]
}

// Advisory U-range hold on a cabinet (DCIM spec §2, agreed decision: advisory not
// blocking). Expiry is enforced by READ-FILTER exclusion (expiresAt > now() OR null)
// — no cron; expired rows stay listed (greyed) until deleted. clientId is a
// denormalised tenancy guard, always = cabinet.site.clientId.
model CabinetReservation {
  id          String    @id @default(uuid())
  cabinetId   String
  cabinet     Cabinet   @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  uStart      Int
  uHeight     Int       @default(1)
  rackSide    String?   // "FRONT" | "REAR" | null = both faces
  name        String    // mandatory — renders in the elevation block
  notes       String?
  expiresAt   DateTime? // app-side default now + 1 month; null = open-ended
  createdById String?   // bare user id, mirrors AuditEvent.actorUserId
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([cabinetId])
  @@index([clientId, expiresAt])
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients Client[]
  users   User[]
}

model User {
  id                    String        @id @default(uuid())
  email                 String        @unique
  passwordHash          String
  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?
  firstName             String?
  lastName              String?
  knownAs               String?
  role                  Role
  organizationId        String?
  organization          Organization? @relation(fields: [organizationId], references: [id])
  isActive              Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  assignedServiceRequests ServiceRequest[]       @relation("AssignedSR")
  assignedIncidents       Incident[]             @relation("AssignedIncident")
  assignedTasks           Task[]                 @relation("AssignedTask")
  assignedRisks           Risk[]                 @relation("AssignedRisk")
  assignedIssues          Issue[]                @relation("AssignedIssue")
  requestIntakes          RequestIntake[]        @relation("RequesterIntake")
  assignedChanges         ChangeRequest[]        @relation("AssignedChange")
  changeApprovals         ChangeApproval[]       @relation("ChangeApprovals")
  comments                Comment[]              @relation("UserComments")
  workNotes               WorkNote[]             @relation("UserWorkNotes")
  assignedChecks          Check[]                @relation("AssignedCheck")
  reviewingChecks         Check[]                @relation("CheckReviewer")
  performedMaintenance    MaintenanceLog[]       @relation("PerformedMaintenance")
  clientAssignments       UserClientAssignment[]
  receivedNotifications   Notification[]         @relation("ReceivedNotifications")
  triggeredNotifications  Notification[]         @relation("TriggeredNotifications")
}

model PublicSubmission {
  id                        String   @id @default(uuid())
  clientId                  String?
  client                    Client?  @relation(fields: [clientId], references: [id])
  requesterName             String
  requesterEmail            String
  subject                   String
  description               String
  status                    String   @default("NEW") // NEW / CONVERTED / REJECTED
  triageNotes               String?
  convertedServiceRequestId String?
  convertedEntityType       String?
  convertedEntityId         String?
  createdAt                 DateTime @default(now())
}

model ServiceRequest {
  id               String               @id @default(uuid())
  reference        String               @unique
  clientId         String
  client           Client               @relation(fields: [clientId], references: [id])
  subject          String
  description      String
  status           ServiceRequestStatus @default(NEW)
  priority         String               @default("medium")
  dueAt            DateTime?
  dueAtManual      Boolean              @default(false)
  closureSummary   String?
  assigneeId       String?
  assignee         User?                @relation("AssignedSR", fields: [assigneeId], references: [id])
  linkedEntityType String?
  linkedEntityId   String?
  createdById      String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  comments         Comment[]            @relation("ServiceRequestComments")

  auditEvents AuditEvent[]
}

// Global hardware catalogue — Manufacturer + DeviceType. NOT client-scoped: a
// "Dell PowerEdge R740" is the same everywhere, shared across tenants (same
// rationale as the shared check-template library). Tenant isolation still applies
// to Assets, which reference a DeviceType via the optional deviceTypeId FK.
model Manufacturer {
  id          String   @id @default(uuid())
  name        String   @unique // "Dell", "Cisco", "APC"
  slug        String   @unique // netbox slug, for seed matching / dedupe
  createdAt   DateTime @default(now())

  deviceTypes DeviceType[]
}

model DeviceType {
  id             String       @id @default(uuid())
  manufacturerId String
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id])
  model          String // "PowerEdge R740"
  slug           String       @unique // netbox slug
  uHeight        Float? // nameplate U height — Float supports 0.5U (half-U kit)
  isFullDepth    Boolean?     @default(true) // consumes both faces — drives the rear elevation view
  powerDrawW     Float? // nameplate power — auto-fills Asset.powerDrawW on placement
  partNumber     String?
  isSeeded       Boolean      @default(false) // true = from NetBox seed, false = user-created (guards re-seed)
  // ── DCIM foundations (spec §1/§3) ──
  weightKg               Float?
  airflow                DeviceAirflow?
  category               String?  // aligns with Asset.assetType vocabulary ("Server", "Switch", …)
  // Blanking panels / cable mgmt: occupy slots for collision but don't count
  // toward fill % (the NetBox occupancy-vs-utilisation distinction).
  excludeFromUtilization Boolean  @default(false)
  deratePct              Int?     // per-type override of DCIM_DEFAULT_DERATE_PCT (60)
  // Elevation images live in object storage DIRECTLY (StorageService), NOT the
  // client-scoped Attachment model — DeviceType is global (spec §3.2).
  frontImageKey          String?
  frontImageType         String?
  rearImageKey           String?
  rearImageType          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt

  assets         Asset[]

  @@unique([manufacturerId, model])
}

model Asset {
  id                  String              @id @default(uuid())
  assetTag            String              @unique
  name                String
  assetType           String
  ownerType           OwnerType
  clientId            String?
  client              Client?             @relation(fields: [clientId], references: [id])
  siteId              String?
  site                Site?               @relation(fields: [siteId], references: [id])
  cabinetId           String?
  cabinet             Cabinet?            @relation(fields: [cabinetId], references: [id])
  // Optional catalogue FK. null = free-text (legacy/manual). The denormalised
  // manufacturer/modelNumber/uHeight/powerDrawW strings below REMAIN — the catalogue
  // populates them, never replaces them. Legacy assets untouched.
  deviceTypeId        String?
  deviceType          DeviceType?         @relation(fields: [deviceTypeId], references: [id])
  status              String              @default("ACTIVE")
  manufacturer        String?
  modelNumber         String?
  serialNumber        String?
  uHeight             Int?
  uPosition           Int?
  // Placement semantics (DCIM spec §2): isFullDepth denormalised from DeviceType
  // at placement (null = full depth, conservative); isZeroU = side-mounted kit
  // (PDU strips etc.) — counts power/weight, never U, uPosition stays null.
  isFullDepth         Boolean?
  isZeroU             Boolean             @default(false)
  powerDrawW          Float? // nameplate watts
  // Budgeted watts (spec §4.1) — ALL capacity maths runs on this, not nameplate.
  // Stamped at placement (nameplate × derate); thereafter a plain editable field.
  // Editing it does NOT clear deviceTypeId (operational data, not a spec copy).
  budgetedDrawW       Float?
  weightKg            Float? // denormalised from DeviceType.weightKg at placement
  // ── Decommission workflow (DCIM_SCHEMA_SPEC §4.1, NOW) ──
  // retired-but-racked interim state: lifecycleState=RETIRED frees capacity
  // immediately (already honoured in the engine), physicallyRemoved=false keeps
  // it drawn (greyed) in the elevation until pulled.
  disposalStatus      String?             // null | "MARKED_FOR_DISPOSAL" | "DISPOSED"
  physicallyRemoved   Boolean             @default(false)
  // ── Monitoring seam (DCIM_SCHEMA_SPEC §6b, LATENT — never populated yet) ──
  healthStatus        String?             // "OK"|"WARNING"|"CRITICAL"|"UNKNOWN"; null = not monitored
  lastTelemetryAt     DateTime?
  ipAddress           String?
  warrantyExpiry      DateTime?
  lifecycleState      AssetLifecycleState @default(ACTIVE)
  hyperviewAssetId    String?
  rackSide            String?             @default("FRONT")
  lastSyncedAt        DateTime?
  notes               String?
  locationType        String?
  locationArea        String?
  location            String?
  lastMaintenanceAt   DateTime?
  // Deletion request-and-approve workflow: ENGINEER/SERVICE_DESK_ANALYST request a
  // delete (sets PENDING); ORG-super/SERVICE_MANAGER approve (hard-delete) or reject
  // (fields cleared back to null). Audit history lives in AuditEvent, keyed by asset id.
  deletionStatus        String?           // null = none | "PENDING"
  deletionRequestedById String?           // bare user id (no FK), mirrors AuditEvent.actorUserId
  deletionRequestedAt   DateTime?
  deletionReason        String?
  // MAC↔ITSM work-order fusion (Horizon 2). A pending physical operation is
  // staged here and APPLIED AUTOMATICALLY when its linked Task/Change completes
  // (the completion hook reverse-looks-up the asset by pendingWorkOrderId). One
  // pending op per asset at a time. Elevation reads these to draw shadow state.
  pendingOp             String?           // null = none | "INSTALL" | "DECOMMISSION" | "MOVE"
  pendingWorkOrderType  String?           // "task" | "change"
  pendingWorkOrderId    String?           // id of the linked Task/Change
  // MOVE target (Phase 2). Set only when pendingOp = "MOVE": the destination the
  // asset relocates to when the work order completes. The target cabinet implies
  // its site. Elevation draws the asset as an "incoming" ghost at this position
  // while it still physically sits at its current cabinet (dual-position shadow).
  pendingTargetCabinetId String?
  pendingTargetUPosition Int?
  pendingTargetRackSide  String?          // "FRONT" | "REAR"
  // User-defined custom properties (register power-features). A flat map of
  // { fieldKey: value }; the field schema lives in AssetCustomField per client.
  // Values travel with the asset (no join table) — the Hyperview pattern.
  customValues          Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  installDate         DateTime?
  maintenanceLogs     MaintenanceLog[]
  outgoingConnections Connection[]        @relation("ConnectionFromAsset")
  incomingConnections Connection[]        @relation("ConnectionToAsset")
  ports               Port[]              // LATENT — port layer (§6)
  floorObjects        FloorObject[]       // reverse of FloorObject.assetId
  sensorReadings      SensorReading[]     // measured power / environmental (Horizon 3)
}

// User-defined asset field schema (register power-features). Per client; drives
// the "Additional properties" card + the register. Values live on Asset.customValues.
model AssetCustomField {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  key       String   // stable identifier used as the customValues map key
  label     String
  type      String   // "text" | "number" | "select" | "date"
  options   String[] // choices for type=select (empty otherwise)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([clientId, key])
  @@index([clientId])
}

// Measured telemetry (DCIM_SCHEMA_SPEC §6b, Horizon 3). The manual/CSV field-
// reading phase — a time-series of point readings per asset. clientId is
// denormalised for the tenant chokepoint on the hot roll-up queries (mirrors
// Connection); the write validates the asset is in scope first. The "third
// number" (measured) that turns estimated stranded capacity into real.
model SensorReading {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  metric       String   // "powerW" | "temperatureC" | "humidityPct"
  value        Float
  readAt       DateTime
  source       String   @default("manual") // "manual" | "csv"
  recordedById String?
  createdAt    DateTime @default(now())

  @@index([clientId, assetId, metric, readAt])
  @@index([assetId, metric, readAt])
}

model MaintenanceLog {
  id            String              @id @default(uuid())
  assetId       String
  asset         Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  workType      MaintenanceWorkType @default(OTHER)
  workTypeOther String?
  performedAt   DateTime
  performedById String?
  performedBy   User?               @relation("PerformedMaintenance", fields: [performedById], references: [id])
  notes         String?
  nextDueAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Connection {
  id              String           @id @default(uuid())
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id])
  fromAssetId     String
  fromAsset       Asset            @relation("ConnectionFromAsset", fields: [fromAssetId], references: [id], onDelete: Cascade)
  toAssetId       String
  toAsset         Asset            @relation("ConnectionToAsset", fields: [toAssetId], references: [id], onDelete: Cascade)
  connectionType  String
  status          ConnectionStatus @default(ACTIVE)
  label           String?
  notes           String?
  // Cable descriptors (DCIM_DESIGN_SPEC §6.1, Horizon 2). connectionType stays the
  // cable/media type (Cat6, 10GBASE-SR, C13); these add the physical run detail.
  cableLength     Float?           // metres
  cableColour     String?
  installedAt     DateTime?
  lastValidatedAt DateTime?
  createdById     String?
  // Port-level endpoints (DCIM_SCHEMA_SPEC §6, LATENT). null = asset-level
  // connection (today's behaviour); populated when cable-tracing is built.
  fromPortId      String?
  fromPort        Port?            @relation("ConnectionFromPort", fields: [fromPortId], references: [id], onDelete: SetNull)
  toPortId        String?
  toPort          Port?            @relation("ConnectionToPort", fields: [toPortId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([clientId, status])
  @@index([fromAssetId])
  @@index([toAssetId])
}

// Port layer beneath Connection (DCIM_SCHEMA_SPEC §6, LATENT — no phase-one UI).
// Defined per-Asset; populating it unlocks the cable-tracing screen with no
// re-architecture. Port templates on DeviceType are a future addition.
model Port {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name       String   // "eth0", "PSU1", "port 24"
  portType   String   // "NETWORK"|"POWER"|"CONSOLE"|"FIBRE"
  position   Int?
  createdAt  DateTime @default(now())

  fromConnections Connection[] @relation("ConnectionFromPort")
  toConnections   Connection[] @relation("ConnectionToPort")

  // Pass-through peer on the SAME asset (patch-panel front↔rear). Symmetric &
  // one-to-one — the service writes both sides; @unique guarantees a port is the
  // pass-through target of at most one other. null = terminal port. A multi-hop
  // cable trace (DCIM_DESIGN_SPEC §6.1, Horizon 2) continues THROUGH a port whose
  // throughPortId is set and stops at a terminal one.
  throughPortId String? @unique
  throughPort   Port?   @relation("PortPassThrough", fields: [throughPortId], references: [id], onDelete: SetNull)
  throughOf     Port?   @relation("PortPassThrough")

  @@index([assetId])
}

